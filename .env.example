# Copy this file to .env for local development.
# In production (e.g. Docker), set these as real environment variables instead.

PORT=3000

# Postgres connection string. When running via docker-compose, "postgres" is
# the service name; when running node directly against docker-compose's
# postgres service, use localhost instead.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/a_dougs_life

# Used by the test suite (npm test). Points at a separate database so tests
# never touch dev data. docker-compose creates this database automatically.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/a_dougs_life_test

# Session cookie signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# Set to "true" once the site is served over HTTPS, so session cookies require it.
SECURE_COOKIES=false

# Admin credentials. Generate these with `npm run create-admin` — it will
# print the ADMIN_PASSWORD_HASH and ADMIN_PASSWORD_SALT values to paste here.
# Never commit real values.
ADMIN_USERNAME=doug
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_SALT=

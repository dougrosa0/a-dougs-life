# Copy this file to .env for local development.
# In production (e.g. Docker), set these as real environment variables instead.

PORT=3000

# Where the SQLite database file lives.
DB_PATH=./data/a-dougs-life.sqlite

# Session cookie signing secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# Set to "true" once the site is served over HTTPS, so session cookies require it.
SECURE_COOKIES=false

# Admin credentials. Generate these with `npm run create-admin` — it will
# print the ADMIN_PASSWORD_HASH and ADMIN_PASSWORD_SALT values to paste here.
# Never commit real values.
ADMIN_USERNAME=doug
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_SALT=
